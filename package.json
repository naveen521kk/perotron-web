  "devDependencies": {
    "@astrojs/check": "^0.9",
    "@eslint/js": "^10",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
