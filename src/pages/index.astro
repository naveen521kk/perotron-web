        <section class="mx-auto w-full max-w-5xl px-4 pb-24" id="tools">
            <div class="mb-12 text-center">
                <h2 class="mb-4 text-3xl font-bold tracking-tight">
                    Featured Tools
                </h2>
            </div>
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                <ToolCard
                    to="/pdf/merge"
                    icon="file-stack"
                    title="PDF Merge"
                    description="Combine multiple PDFs into one document."
                    client:load
                />
                <ToolCard
                    to="/pdf/split"
                    icon="scissors"
                    title="PDF Split"
                    description="Extract individual pages from a PDF."
                    client:load
                />
                <ToolCard
                    to="/qr/generator"
                    icon="qr-code"
                    title="QR Generator"
                    description="Create custom QR codes."
                    client:load
                />
            </div>
        </section>

        {/* ── Philosophy ─────────────────────────────────────────────── */}
        <section class="mx-auto w-full max-w-3xl px-4 py-24 text-center">
            <h2 class="mb-6 text-3xl font-bold tracking-tight">
                Designed for Local Computing
            </h2>
            <p class="text-lg leading-relaxed text-muted-foreground">
                We believe powerful software doesn't always need a server.
                Perotron Web brings modern computing directly into your browser
                using WebAssembly, allowing you to process documents, analyze
                data, transform files, and build workflows while keeping control
                of your information.
            </p>
        </section>

