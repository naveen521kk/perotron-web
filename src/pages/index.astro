    // Video,
    // Sparkles,
    // Wrench,
    // Download,
    Zap,
    WifiOff,
    FileDown,
    ArrowRight,
    ServerOff,
} from "lucide-react"

import {
    FeatureCard,
    ToolCard,
    // CategoryBadge,
    HeroButtons,
} from "@/components/react/index-page"
import { FooterAdBanner } from "@/components/react/ad-banner"
---

<Layout>
    <div class="flex w-full flex-1 flex-col items-center">
        <section
            class="mx-auto flex w-full max-w-4xl animate-in flex-col items-center gap-8 px-4 pt-24 pb-16 text-center"
            id="hero"
        >
            <div class="space-y-4">
                <h1
                    class="text-5xl leading-[1.1] font-bold tracking-tight text-foreground md:text-[5rem] lg:text-[5.5rem]"
                >
                    Perotron Web
                </h1>
                <p
                    class="mx-auto max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl"
                >
                    Browser-native tools for developers, analysts, and
                    professionals. Fast, private, and built to work entirely on
                    your device.
                </p>
            </div>

            <div class="mt-4 flex w-full flex-col gap-4 sm:w-auto sm:flex-row">
                <HeroButtons client:load />
            </div>

            <div
                class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm font-medium text-muted-foreground"
            >
                <div class="flex items-center gap-1.5">
                    <ShieldCheck className="size-4 text-primary" /> Runs Locally
                </div>
                <div class="flex items-center gap-1.5">
                    <Code2 className="size-4 text-primary" /> Open Source
                </div>
                <div class="flex items-center gap-1.5">
                    <Lock className="size-4 text-primary" /> Privacy First
                </div>
                <div class="flex items-center gap-1.5">
                    <WifiOff className="size-4 text-primary" /> Works Offline*
                </div>
                <div class="flex items-center gap-1.5">
                    <FileDown className="size-4 text-primary" /> No File Uploads
                </div>
            </div>
            <p class="text-xs text-muted-foreground/60">
                * Offline after installation or once resources are cached.
            </p>
        </section>

        <section
            class="w-full border-y border-border/50 bg-primary/5 px-4 py-12 text-center"
        >
            <div class="mx-auto max-w-3xl">
                <h2
                    class="text-xl font-medium tracking-tight text-foreground md:text-2xl"
                >
                    No uploads. No accounts. No subscriptions.
                    <br />
                    <span class="mt-2 inline-block font-semibold text-primary">
                        Just fast, private tools.
                    </span>
                </h2>
                <p
                    class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-muted-foreground"
                >
                    Perotron Web is a collection of browser-native tools powered
                    by modern Web technologies like WebAssembly. Your files and
                    data stay on your device—nothing is uploaded unless you
                    explicitly choose to.
                </p>
            </div>
        </section>

        {/* ── Why Perotron? ─────────────────────────────────────────────── */}
        <section class="mx-auto w-full max-w-6xl px-4 py-24" id="why">
            <div class="mb-16 text-center">
                <h2 class="mb-4 text-3xl font-bold tracking-tight">
                    Why Perotron?
                </h2>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
                <FeatureCard
                    icon="server-off"
                    title="Browser-Native"
                    description="Everything runs directly in your browser. No waiting for uploads. No server-side processing."
                    client:load
                />
                <FeatureCard
                    icon="lock"
                    title="Privacy by Default"
                    description="Your documents, images, and data remain on your device. No hidden uploads or unnecessary tracking."
                    client:load
                />
                <FeatureCard
                    icon="zap"
                    title="Fast"
                    description="Powered by WebAssembly and optimized for modern browsers. Desktop-class performance."
                    client:load
                />
                <FeatureCard
                    icon="code-2"
                    title="Open Source"
                    description="Built in the open. Review the source, self-host or contribute new tools."
                    client:load
                />
            </div>
        </section>

