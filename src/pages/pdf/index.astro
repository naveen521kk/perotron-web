---
import Layout from "@/layouts/main.astro"

import { Badge } from "@/components/react/ui/badge"
import { ToolCard } from "@/components/react/index-page.tsx"
import { ShieldCheck } from "lucide-react"

const title = "PDF Tools — Merge, Split & Edit PDFs Free Online | Perotron Web"
const description =
    "Free, privacy-first PDF tools powered by WebAssembly. Merge multiple PDFs into one, split a PDF into separate files, and more — all inside your browser. No uploads, no accounts."
---

<Layout title={title} description={description}>
    <div class="flex w-full flex-1 flex-col items-center px-4">
        {/* ── Hero ─────────────────────────────────────────────── */}
        <section
            class="mx-auto flex w-full max-w-3xl animate-in flex-col items-center gap-6 pt-20 pb-12 text-center duration-700 fade-in slide-in-from-bottom-6"
        >
            <Badge
                variant="secondary"
                className="gap-1.5 px-3 py-1 text-xs font-semibold tracking-widest uppercase"
            >
                <ShieldCheck className="size-3.5" />
                100% browser-based
            </Badge>

            <h1
                class="text-5xl leading-[1.1] font-bold tracking-tight text-foreground md:text-[4rem]"
            >
                PDF Tools
            </h1>

            <p
                class="max-w-xl text-lg leading-relaxed text-muted-foreground md:text-xl"
            >
                Merge, split, and manipulate PDFs entirely in your browser. Your
                files never leave your device — powered by WebAssembly.
            </p>
        </section>

        {/* ── Tools grid ───────────────────────────────────────── */}
        <section class="mx-auto w-full max-w-3xl pb-20">
            <p
                class="mb-5 text-xs font-semibold tracking-widest text-muted-foreground uppercase"
            >
                Available PDF tools
            </p>
            <div class="grid gap-4 md:grid-cols-2">
                <ToolCard
                    to="/pdf/merge"
                    icon="file-stack"
                    title="Merge PDF"
                    description="Combine multiple PDFs into one document. Arrange them in the order you need, then download."
                    iconClassNames="size-6"
                    client:load
                />
                <ToolCard
                    to="/pdf/split"
                    icon="scissors"
                    title="Split PDF"
                    description="Extract individual pages or split a large PDF into separate files, all without uploading anything."
                    iconClassNames="size-6"
                    client:load
                />
            </div>
            <p class="mt-6 text-center text-xs text-muted-foreground">
                More PDF tools coming soon.
            </p>
        </section>
    </div>
</Layout>
