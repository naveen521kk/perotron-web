---
import { Image } from "astro:assets"
import logoLight from "@/assets/logo-light.svg"
import logoDark from "@/assets/logo-dark.svg"
---

<Image
    src={logoLight}
    alt="Perotron Web"
    width={40}
    height={40}
    class="block dark:hidden"
    loading="eager"
/>
<Image
    src={logoDark}
    alt="Perotron Web"
    width={40}
    height={40}
    class="hidden dark:block"
    loading="eager"
/>
