---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/react/ui/button"
import {
    FileStack,
    Scissors,
    ShieldCheck,
    Code2,
    QrCode,
    // FileText,
    // Image as ImageIcon,
    // Terminal,
