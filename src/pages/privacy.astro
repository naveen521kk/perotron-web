---
import Layout from "@/layouts/main.astro"
import ExternalLink from "@/components/external-link.astro"

import { Separator } from "@/components/react/ui/separator"

const title = "Privacy Policy — Perotron Web"
const description =
    "Privacy Policy for Perotron Web. Learn how we handle your data, our local-first browser-native processing model, and third-party services including Google Analytics, Google AdSense, and PostHog."
---

<Layout title={title} description={description}>
    <div
        class="container mx-auto flex max-w-3xl animate-in flex-col gap-6 px-4 py-12 duration-300 fade-in"
    >
        <div class="flex flex-col gap-2">
            <h1
                class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
            >
                Privacy Policy
            </h1>
            <p class="text-sm text-muted-foreground">
                Last updated: July 4, 2026
            </p>
        </div>

        <Separator />

        {/* Section 1 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                1. Introduction
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Welcome to{" "}
                <strong class="font-semibold text-foreground"
                    >Perotron Web</strong
                >{" "}
                (&ldquo;Perotron&rdquo;, &ldquo;we&rdquo;, &ldquo;our&rdquo;, or &ldquo;us&rdquo;).
            </p>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Perotron Web is an open-source, browser-native platform that
                provides document, developer, data, security, and productivity
                tools. Our design philosophy is:
            </p>
            <div
                class="rounded-r-md border-l-4 border-primary/50 bg-primary/5 px-4 py-3"
            >
                <p
                    class="text-sm font-semibold text-foreground italic md:text-base"
                >
                    Compute locally. Work privately.
                </p>
            </div>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Most processing performed by Perotron Web occurs entirely within
                your web browser. Whenever possible, files and data remain on
                your device and are never transmitted to our servers.
            </p>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                This Privacy Policy explains what information we collect, how we
                use it, and your rights.
            </p>
        </section>

        <Separator />

        {/* Section 2 */}
        <section class="flex flex-col gap-5">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                2. What We Collect
            </h2>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    A. Information You Provide
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    Most Perotron tools do not require you to create an account.
                    Unless explicitly stated for a particular feature, we do not
                    collect:
                </p>
                <ul
                    class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
                >
                    <li class="leading-relaxed">Uploaded files</li>
                    <li class="leading-relaxed">
                        Document contents, images, PDFs, or spreadsheets
                    </li>
                    <li class="leading-relaxed">
                        Passwords or encryption keys
                    </li>
                    <li class="leading-relaxed">Generated output</li>
                </ul>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    These remain on your device during processing.
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    B. Usage Analytics
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    We use analytics services to understand how Perotron Web is
                    used and to improve performance and usability. This may
                    include information such as:
                </p>
                <ul
                    class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
                >
                    <li class="leading-relaxed">
                        Pages visited and tools used
                    </li>
                    <li class="leading-relaxed">
                        Browser type, operating system, and screen resolution
                    </li>
                    <li class="leading-relaxed">Language preferences</li>
                    <li class="leading-relaxed">
                        Approximate geographic region (derived from IP by
                        analytics providers)
                    </li>
                    <li class="leading-relaxed">
                        Referrer information and session duration
                    </li>
                    <li class="leading-relaxed">
                        Interaction events, feature usage, and performance
                        metrics
                    </li>
                    <li class="leading-relaxed">
                        Crash reports and anonymous identifiers
                    </li>
                </ul>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    Analytics providers may collect IP addresses as part of
                    providing their services, although they may process,
                    truncate, or anonymize them according to their own policies.
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    C. Tool Metrics
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    Some tools may collect non-content operational metrics to
                    improve functionality. Examples include:
                </p>
                <ul
                    class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
                >
                    <li class="leading-relaxed">
                        Number of pages in a PDF and file size
                    </li>
                    <li class="leading-relaxed">
                        Processing duration and memory usage
                    </li>
                    <li class="leading-relaxed">
                        Processing success or failure
                    </li>
                    <li class="leading-relaxed">
                        Browser performance and tool version
                    </li>
                </ul>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    We do not intentionally collect the contents of your
                    documents for analytics.
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    D. Local Storage
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    Perotron stores information locally on your device using
                    browser storage technologies, including IndexedDB, Local
                    Storage, Cache Storage, and Service Workers. These may be
                    used for recent tools, favorites, settings, theme
                    preferences, offline functionality, and cached application
                    assets.
                </p>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    This data remains on your device unless you clear your
                    browser storage.
                </p>
            </div>
        </section>

        <Separator />

        {/* Section 3 */}
        <section class="flex flex-col gap-5">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                3. Analytics and Third-Party Services
            </h2>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    Google Analytics
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    We use{" "}
                    <ExternalLink
                        href="https://policies.google.com/technologies/partner-sites"
                    >
                        Google Analytics
                    </ExternalLink>{" "}
                    to understand website traffic, user engagement, and improve the
                    platform. Google may collect information in accordance with its
                    own privacy policies.
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">
                    Google AdSense
                </h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    Some pages may display advertisements served by{" "}
                    <ExternalLink
                        href="https://policies.google.com/technologies/partner-sites"
                    >
                        Google AdSense
                    </ExternalLink>
                    . Google and its partners may use cookies or similar technologies
                    to personalize advertising and measure ad performance. Users may
                    manage ad personalization through{" "}
                    <ExternalLink href="https://adssettings.google.com/">
                        Google&apos;s Ad Settings
                    </ExternalLink>
                    .
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h3 class="text-lg font-semibold text-foreground">PostHog</h3>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    We use{" "}
                    <ExternalLink href="https://posthog.com/privacy">
                        PostHog
                    </ExternalLink>{" "}
                    for product analytics and performance monitoring. PostHog helps
                    us understand which tools are used, application performance, feature
                    adoption, browser compatibility, anonymous usage patterns, and
                    operational metrics (such as PDF page count or processing duration).
                </p>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    PostHog is configured to send analytics through <ExternalLink
                        href="https://www.cloudflare.com/trust-hub/"
                        >Cloudflare</ExternalLink
                    > as a reverse proxy. Analytics data is ultimately processed using
                    PostHog&apos;s United States cloud infrastructure.
                </p>
                <p
                    class="text-sm leading-relaxed text-muted-foreground md:text-base"
                >
                    We do not intentionally send document contents or file data
                    to PostHog.
                </p>
            </div>
        </section>

        <Separator />

        {/* Section 4 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                4. Cookies
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Perotron and our third-party providers may use cookies or
                similar technologies for:
            </p>
            <ul
                class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
            >
                <li class="leading-relaxed">Analytics</li>
                <li class="leading-relaxed">Remembering preferences</li>
                <li class="leading-relaxed">Authentication</li>
                <li class="leading-relaxed">
                    Advertising, security, and fraud prevention
                </li>
            </ul>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                You can control cookies through your browser settings. Disabling
                certain cookies may affect some functionality.
            </p>
        </section>

        <Separator />

        {/* Section 5 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                5. File Processing
            </h2>
            <div
                class="rounded-r-md border-l-4 border-primary/50 bg-primary/5 px-4 py-3"
            >
                <p
                    class="text-sm font-semibold text-foreground italic md:text-base"
                >
                    Your files should stay on your device whenever possible.
                </p>
            </div>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Most tools process files entirely within your browser using
                technologies such as:
            </p>
            <ul
                class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
            >
                <li class="leading-relaxed">WebAssembly (WASM) and Pyodide</li>
                <li class="leading-relaxed">
                    DuckDB WASM and ONNX Runtime Web
                </li>
                <li class="leading-relaxed">Browser APIs</li>
            </ul>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Files are generally not uploaded to our servers for processing.
                If a future tool requires cloud processing or an external API,
                that tool will clearly disclose this before any data is
                transmitted.
            </p>
        </section>

        <Separator />

        {/* Section 6 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                6. Data Retention
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Analytics providers retain data according to their own retention
                policies. Locally stored preferences remain on your device until
                you remove them or clear your browser data.
            </p>
        </section>

        <Separator />

        {/* Section 7 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                7. International Data Transfers
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Some analytics and advertising providers may process data
                outside your country of residence. In particular:
            </p>
            <ul
                class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
            >
                <li class="leading-relaxed">
                    PostHog analytics are processed in the United States.
                </li>
                <li class="leading-relaxed">
                    Google services may process information in multiple
                    jurisdictions.
                </li>
            </ul>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Where applicable, these providers use mechanisms intended to
                safeguard international data transfers.
            </p>
        </section>

        <Separator />

        {/* Section 8 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                8. Security
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                We use reasonable technical and organizational measures to
                protect the platform, including:
            </p>
            <ul
                class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
            >
                <li class="leading-relaxed">HTTPS encryption</li>
                <li class="leading-relaxed">Cloudflare security services</li>
                <li class="leading-relaxed">
                    Content Security Policy where applicable
                </li>
                <li class="leading-relaxed">
                    Browser sandboxing and local processing whenever possible
                </li>
            </ul>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                No method of transmission or storage is completely secure.
            </p>
        </section>

        <Separator />

        {/* Section 9 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                9. Children&apos;s Privacy
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Perotron Web is not directed toward children under the age
                required by applicable law to consent to data processing.
            </p>
        </section>

        <Separator />

        {/* Section 10 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                10. Open Source
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Perotron Web is an open-source project. Source code is publicly
                available, allowing anyone to inspect how the platform operates.
            </p>
        </section>

        <Separator />

        {/* Section 11 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                11. Changes to This Policy
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                We may update this Privacy Policy from time to time. Material
                changes will be reflected by updating the &ldquo;Last
                updated&rdquo; date.
            </p>
        </section>

        <Separator />

        {/* Section 12 */}
        <section class="flex flex-col gap-3">
            <h2
                class="text-xl font-bold tracking-tight text-foreground md:text-2xl"
            >
                12. Contact
            </h2>
            <p
                class="text-sm leading-relaxed text-muted-foreground md:text-base"
            >
                Questions regarding this Privacy Policy may be submitted
                through:
            </p>
            <ul
                class="flex list-disc flex-col gap-1.5 pl-6 text-sm text-muted-foreground md:text-base"
            >
                <li class="leading-relaxed">
                    <ExternalLink
                        href="https://github.com/naveen521kk/perotron-web/issues"
                    >
                        GitHub Issues
                    </ExternalLink>
                </li>
                <li class="leading-relaxed">
                    The project&apos;s official contact methods listed on the
                    website
                </li>
            </ul>
        </section>
    </div>
</Layout>
